{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "d5a0338a95cd42828131819c8ceca094",
    "m_Title": "Design Decisions",
    "m_Content": "- Raymarching has a loop which runs `stepCount` times and `StepSize` determines the quality. Smaller step size outputs more precise image. \n- However the minimum step size should be 1 / stepCount. Otherwise ray may not hit the model and this results in invisible model.\n\n- There are three design options which should mitigate accidents:\n\t1. Fix the `stepCount` to an optimized number (e.g. between 100 - 250). And clamp step size to minimum (1 / step count) and maximum.\n\t2. Fix the `stepSize` to minimum to ensure maximum quality within the given step count.\n\t3. Make both adjustable via UI and clamp minimum and maximum step size according to the step number.\nTrue Solution: Create a new variable called `MaxDepth` or `RayQuality` and make it UI-adjustable. This is analogous to solution 1.  ",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1227.0,
        "y": 534.0,
        "width": 454.0,
        "height": 289.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

